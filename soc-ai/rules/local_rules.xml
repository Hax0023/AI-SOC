<group name="soc-lab,attack,brute-force">

  <!-- Rule 100001: Fires on EVERY non-existent user attempt (chains from 5710) -->
  <rule id="100001" level="10">
    <if_sid>5710</if_sid>
    <description>SOC-LAB: SSH login attempt with non-existent user $(srcuser) from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,brute_force</group>
  </rule>

  <!-- Rule 100002: Brute force — 8+ attempts from same IP (chains from 100001) -->
  <rule id="100002" level="14" frequency="8" timeframe="120">
    <if_matched_sid>100001</if_matched_sid>
    <same_source_ip />
    <description>SOC-LAB: SSH Brute Force Detected! $(frequency) attempts from $(srcip)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failures,brute_force,pci_dss_10.2.4</group>
  </rule>

  <!-- Rule 100003: Auth failure on real user -->
  <rule id="100003" level="10">
    <if_sid>5716</if_sid>
    <description>SOC-LAB: SSH authentication failed for user $(srcuser) from $(srcip)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failures</group>
  </rule>

  <!-- Rule 100004: Brute force on real user -->
  <rule id="100004" level="14" frequency="8" timeframe="120">
    <if_matched_sid>100003</if_matched_sid>
    <same_source_ip />
    <description>SOC-LAB: SSH Brute Force on real user! $(frequency) attempts from $(srcip)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failures,brute_force</group>
  </rule>

</group>
